import numpy as np

# to create the archive  
np.savez("submission.npz", Yhat1=Yhat1, Yhat2=Yhat2)

def simulate_narx1(N, sigma2, u=None):
    # Initialisation à zéro 
    y1 = np.zeros(N + 1)
    y2 = np.zeros(N + 1)
    if u is None:
        u = np.random.normal(0, 1, N + 1) # Entrée aléatoire si non fournie
    
    # noise  gaussian N(0, sigma2) 
    w1 = np.random.normal(0, np.sqrt(sigma2), N + 1)
    w2 = np.random.normal(0, np.sqrt(sigma2), N + 1)

    for k in range(1, N):
        y1[k+1] = 0.5 * y2[k-1] + np.sin(y2[k]) + 0.3 * u[k-1] + w1[k+1] [cite: 71]
        y2[k+1] = 0.5 * y1[k-1] + np.sin(y1[k]) + 0.2 * u[k] + w2[k+1] [cite: 71]
    
    return u, np.column_stack((y1, y2))